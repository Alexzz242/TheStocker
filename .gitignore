# Godot 4+ specific ignores
.godot/

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# C# / .NET build artifacts
bin/
obj/
*.csproj.user
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# IDEs
.vs/
.vscode/
.idea/
*.DotSettings.user
*.sln.iml

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Exported game builds
builds/
exports/
export/
dist/
*.exe
*.pck
*.zip
*.apk
*.ipa
*.dmg

# Addons - only build artifacts (keep source code)
addons/*/bin/
addons/*/obj/
addons/godot-git-plugin/

# 3D Model backup files (keep original models)
*.blend1
*.blend2
*.blend3
*.blend~
*.mb.swatches
*.max.bak

# Image editor source files (large files)
*.psd
*.xcf
*.kra
*.ora
*.aseprite-bak

# Audio source files (uncompressed)
*.aif
*.aiff

# Video source files
*.avi
*.mov
*.mp4.bak

# Shader and import backups
*.import.bak
*.shader.import

# Auto-generated files
*.gen.*
*.generated.*

# System and OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor temporary files
*.swp
*.swo
*.swn
*.bak
*.tmp
*.temp
*~

# Log files
*.log

# Android/iOS build artifacts
android/build/
android/.gradle/
android/local.properties
android/.cxx/
ios/build/
ios/Pods/
ios/*.xcworkspace/

# SCons build cache (if building engine from source)
.sconsign.dblite
.scons_env.json

# Crash reports
mono_crash.*
crash_handler_*.txt
godot_crash_*.txt

# Profiler data
*.prof

# Documentation build
docs/_build/

# Python cache (if using Python tools)
__pycache__/
*.py[cod]
*$py.class

# Node modules (if using web export or tools)
node_modules/
package-lock.json
yarn.lock

# Environment variables and secrets
.env
.env.local
*.key
*.pem
credentials.json
secrets.json

# Large media files that should use Git LFS
# Uncomment if you're using Git LFS:
# *.fbx
# *.blend
# *.wav
# *.mp3
# *.ogg
# *.png
# *.jpg
# *.hdr
